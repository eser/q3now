[Unit]
Description=This service spawns an q3now Internet server
# A map will need to be loaded for players to be able to join.
# For additional settings see https://q3now.com/

[Service]
User=q3now
ExecStart=/usr/local/games/q3now/q3now.ded +set dedicated 2
Restart=on-abort

[Install]
WantedBy=multi-user.target
