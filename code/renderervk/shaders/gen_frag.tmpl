#endif

// Phase 6B3'-d4-A2/A3 / m_final: precise piecewise sRGB <-> linear
// conversion (sRGB EOTF / OETF). Matches RBDOOM-3-BFG and Daemon
// Engine convention and the renderer's CPU-side mipmap LUTs (Phase
// 6B3'-d3-C) — the pow(x, 2.2) approximation is rejected so the
// colour-space pipeline stays precise end-to-end. The defensive
// max(c, 0.0) guards against negatives that could reach these from a
// float-FBO read in future use (a UNORM texture sample is already
// non-negative). Duplicated in light_frag.tmpl because compile.mjs
// has no #include support — if a third consumer appears, revisit
// build-infra.
vec3 sRGBToLinear( vec3 c ) {
	c = max( c, vec3( 0.0 ) );
	bvec3 cutoff = lessThanEqual( c, vec3( 0.04045 ) );
	vec3 lo = c / 12.92;
	vec3 hi = pow( ( c + vec3( 0.055 ) ) / 1.055, vec3( 2.4 ) );
	return mix( hi, lo, vec3( cutoff ) );
}

vec3 linearToSRGB( vec3 c ) {
	c = max( c, vec3( 0.0 ) );
	bvec3 cutoff = lessThanEqual( c, vec3( 0.0031308 ) );
	vec3 lo = c * 12.92;
	vec3 hi = pow( c, vec3( 1.0 / 2.4 ) ) * 1.055 - 0.055;
	return mix( hi, lo, vec3( cutoff ) );
}

// Block 5d: domain-aware colour-texture fetch. Each texture slot carries a
// colour-domain bit in the `tex_domain` spec constant (host-filled from
// image_t.colorDomain — auto-classified by filename suffix, overridable via
// the linearMap / srgbMap / gammaMap shader keywords). CD_SRGB texels (the
// default — normal diffuse/albedo/colour content) are sRGB display data and
// get decoded sRGB->linear here, before the call-site vertex/entity-colour
// multiply (which is itself linear). CD_LINEAR texels (normal/spec/roughness/
// metallic/AO/height masks, framebuffer reads) are linear data and are
// fetched raw — this replaces the Block-5c sampleColorTexRaw special case
// (tex_mode 7 spec masks) with a universal mechanism. Alpha is never an sRGB
// quantity; it always passes through unchanged.
vec4 sampleColorTex( sampler2D s, vec2 uv, int slot ) {
	vec4 c = texture( s, uv );
	if ( ( tex_domain & ( 1 << slot ) ) != 0 )
		return c;	// CD_LINEAR — raw
	c.rgb = sRGBToLinear( c.rgb );
	return c;		// CD_SRGB — decoded
}

void main() {
#ifdef USE_FOG
	vec4 fog = texture(fog_texture, fog_tex_coord);
#endif

	// Phase 6B3'-d4-m8: decode the rgbGen vertex colours (loc 0/5/6) to
	// linear domain. They are display-domain byte streams; every blend
	// below (modulate / add / mix / premultiplied-alpha) expects linear
	// operands — the texels are already linear via sampleColorTex (A3),
	// so the vertex multiplier must match. Alpha is per-stage state
	// (alphaGen), never sRGB-encoded — left raw. (USE_FIXED_COLOR's
	// identity_color/identity_alpha and USE_ENT_COLOR's ent_color* are
	// handled elsewhere: the former is the per-pipeline fixed RGBA from
	// def->color (constant_id 8/9 — vk_create_pipeline writes
	// def->color.rgb/255 and def->color.alpha/255 into them), used in
	// the USE_FIXED_COLOR path; it is NOT 1.0 and must NOT be replaced
	// with a literal. The latter is decoded host-side at the UBO fill
	// site.)
#if !defined (USE_CLX_IDENT)
#if !( defined (USE_FIXED_COLOR) || defined (USE_ENT_COLOR) )
	vec4 frag_color0 = vec4( sRGBToLinear( frag_color0In.rgb ), frag_color0In.a );
#endif
#ifdef USE_CL1
	vec4 frag_color1 = vec4( sRGBToLinear( frag_color1In.rgb ), frag_color1In.a );
#endif
#ifdef USE_CL2
	vec4 frag_color2 = vec4( sRGBToLinear( frag_color2In.rgb ), frag_color2In.a );
#endif
#endif

	// Phase 6B3'-d4-m8: tex_mode blend contracts (spec constant id 6).
	// All branches were authored with domain-agnostic math; once the
	// texel (sampleColorTex) and vertex/entity colour operands are
	// linear they become colorimetrically correct:
	//   0  modulate  — diffuse × lightmap[× detail], plus LIGHTMAP_BOOST
	//                  (×2.0) on the lightmap term (color1) — unconditional
	//                  (m_final; was srgb-gated under A5). The ONLY branch
	//                  that consumes a lightmap — add/mix/blend branches
	//                  collapse non-lightmap stages.
	//   1/2 add       — Σ colorN.rgb : linear radiance sum (physical).
	//   3  mod-by-a   — Σ (colorN × colorN.a) : premultiplied-alpha sum.
	//   4  mod-by-1-a — Σ (colorN × (1-colorN.a)).
	//   5  mix-by-a   — nested mix() : linear-domain alpha blend.
	//   6  mix-by-1-a — nested mix(), reversed.
	//   7  exact emulation of the fixed-function blend chain
	//      GLS_SRCBLEND_DST_COLOR | GLS_DSTBLEND_SRC_ALPHA: for each stage N,
	//      fb' = (texN·colN)·fb + fb·(texN·colN).a = fb·((texN·colN)+(texN·colN).a),
	//      so the collapsed product is  color0 · Π_N (colorN + colorN.a)
	//      (the GLSL vec4+scalar broadcast also reproduces the blend's alpha,
	//      fb'.a = 2·src.a·fb.a). Domain-agnostic — correct in linear now that
	//      the operands are linear, just as it was correct in gamma when they
	//      were gamma; nothing here was "tuned" against any pipeline. Used by
	//      Team Arena "shiny/specular" stages (blendFunc GL_DST_COLOR GL_SRC_ALPHA
	//      + alphaGen lightingSpecular over a base/$lightmap stage) and a few
	//      liquid/effect surfaces — NOT detail maps, NOT a lightmap. The
	//      greyscale spec-mask texels in colorN are not sRGB-decoded —
	//      R_ClassifyColorDomain flags _spec/_shiny/_s/etc. textures CD_LINEAR
	//      (or a `linearMap` shader keyword forces it), so sampleColorTex
	//      fetches them raw via the tex_domain bit — because the artist
	//      authored them in gamma space co-tuned with the linear
	//      lightingSpecular alpha term (Block 5d; was the 5c sampleColorTexRaw
	//      special case, now the universal per-texture domain mechanism).
	// No structural math change in m8 — only the operand decodes above.

#if defined (USE_CLX_IDENT)
	vec4 color0 = sampleColorTex(texture0, frag_tex_coord0, 0);
#elif defined (USE_FIXED_COLOR)
	const vec4 frag_color = vec4(identity_color, identity_color,identity_color, identity_alpha);
	vec4 color0 = sampleColorTex(texture0, frag_tex_coord0, 0) * frag_color;
#elif defined (USE_ENT_COLOR)
	vec4 color0 = sampleColorTex(texture0, frag_tex_coord0, 0) * ent_color0;
#else
	vec4 color0 = sampleColorTex(texture0, frag_tex_coord0, 0) * frag_color0;
#endif
	vec4 base;

	// triple-texture with non-identity colors in color1 and color2
#if defined (USE_TX2)
#ifdef USE_CL2
	// special blend modes for non-identity colors
	if ( tex_mode == 1 || tex_mode == 2 )
	{
		// add
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * ent_color2;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color2;
#endif

		base = vec4( color0.rgb + color1.rgb + color2.rgb, color0.a * color1.a * color2.a );
	}
	else if ( tex_mode == 3 )
	{
		// modulate by alpha
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * ent_color2;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color2;
#endif
		color0 *= color0.a;
		color1 *= color1.a;
		color2 *= color2.a;
		base = vec4( color0.rgb + color1.rgb + color2.rgb, color0.a * color1.a * color2.a );
	}
	else if ( tex_mode == 4 )
	{
		// modulate by 1.0-alpha
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * ent_color2;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color2;
#endif
		color0 *= 1.0-color0.a;
		color1 *= 1.0-color1.a;
		color2 *= 1.0-color2.a;
		base = vec4( color0.rgb + color1.rgb + color2.rgb, color0.a * color1.a * color2.a );
	}
	else if ( tex_mode == 5 )
	{
		// mix by src alpha
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * ent_color2;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color2;
#endif
		//base = mix( color0, color1, color1.a );
		//base = mix( base, color2, color2.a );
		base = mix( mix( color0, color1, color1.a ), color2, color2.a );
	}
	else if ( tex_mode == 6 )
	{
		// mix by 1-src alpha
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * ent_color2;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color2;
#endif
		//base = mix( color1, color0, color1.a );
		//base = mix( color2, base, color2.a );
		base = mix( color2, mix( color1, color0, color1.a ), color2.a );
	}
	else if ( tex_mode == 7 ) // tex_mode 7: 3-stage GLS_SRCBLEND_DST_COLOR | GLS_DSTBLEND_SRC_ALPHA chain
	{
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * ent_color2;
#else
		// tex_mode 7: spec-mask modulator texels fetched raw (no sRGB
		// decode) — artist-authored in gamma space, co-tuned with the
		// linear lightingSpecular alpha carried in frag_color1/2.
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color2;
#endif
		base = (color2 + color2.a) * (color1 + color1.a) * color0;
	}
	else
	{
		// default case, modulate
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * ent_color2;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color2;
#endif
		// Phase 6B3'-d4-A5 / m_final: lightmap boost on color1 only (MUL3
		// collapse — color1 = lightmap, color2 = third stage). The
		// lightmap texel is stored byte-verbatim now (R_ColorShiftLightingBytes
		// no longer << 1's it); the ×2.0 happens here, in linear domain.
		base.rgb = color0.rgb * color1.rgb * color2.rgb * LIGHTMAP_BOOST;
		base.a   = color0.a * color1.a * color2.a;
	}
#else // !USE_CL2
	// triple-texture with identity colors (1.0) in color1 and color2
	if ( tex_mode == 1 )
	{
		// add (identity color0 == 1.0)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2);
		base = vec4(color0.rgb + color1.rgb + color2.rgb, color0.a * color1.a * color2.a);
	}
	else if ( tex_mode == 2 )
	{
		// add (color0 != 1.0)
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * ent_color2;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color0;
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2) * frag_color0;
#endif
		base = vec4(color0.rgb + color1.rgb + color2.rgb, color0.a * color1.a * color2.a);
	}
	else
	{
		// default case, modulate
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
		vec4 color2 = sampleColorTex(texture2, frag_tex_coord2, 2);
		// Phase 6B3'-d4-A5 / m_final: lightmap boost on color1 only (MUL3
		// collapse — color1 = lightmap, color2 = third stage). The
		// lightmap texel is stored byte-verbatim now (R_ColorShiftLightingBytes
		// no longer << 1's it); the ×2.0 happens here, in linear domain.
		base.rgb = color0.rgb * color1.rgb * color2.rgb * LIGHTMAP_BOOST;
		base.a   = color0.a * color1.a * color2.a;
	}
#endif // !USE_TX2
#elif defined(USE_TX1)
	// double-texture with non-identity colors in color1
#ifdef USE_CL1
	// special blend modes for non-identity colors
	if ( tex_mode == 1 || tex_mode == 2 )
	{
		// add
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
#endif
		base = vec4( color0.rgb + color1.rgb, color0.a * color1.a );
	}
	else if ( tex_mode == 3 ) // 2x GLS_DSTBLEND_ONE | GLS_SRCBLEND_SRC_ALPHA
	{
		// modulate by alpha
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
#endif
		color0 *= color0.a;
		color1 *= color1.a;
		base = vec4( color0.rgb + color1.rgb, color0.a * color1.a );
	}
	else if ( tex_mode == 4 ) // 2x GLS_DSTBLEND_ONE | GLS_SRCBLEND_ONE_MINUS_SRC_ALPHA
	{
		// modulate by 1.0-alpha
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
#endif
		color0 *= 1.0-color0.a;
		color1 *= 1.0-color1.a;
		base = vec4( color0.rgb + color1.rgb, color0.a * color1.a );
	}
	else if ( tex_mode == 5 ) // 0 + GLS_DSTBLEND_ONE_MINUS_SRC_ALPHA | GLS_SRCBLEND_SRC_ALPHA
	{
		// mix by src alpha
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
#endif
		base = mix( color0, color1, color1.a );
	}
	else if ( tex_mode == 6 ) // 0 + GLS_DSTBLEND_SRC_ALPHA | GLS_SRCBLEND_ONE_MINUS_SRC_ALPHA
	{
		// mix by 1-src alpha
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
#endif
		base = mix( color1, color0, color1.a );
	}
	else if ( tex_mode == 7 ) // tex_mode 7: 2-stage GLS_SRCBLEND_DST_COLOR | GLS_DSTBLEND_SRC_ALPHA chain
	{
		// tex_mode 7: fb = color0·(color1 + color1.a)
		//   — DST_COLOR|SRC_ALPHA blend of stage 1 over stage 0
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
#else
		// tex_mode 7: spec-mask modulator texel fetched raw (no sRGB
		// decode) — artist-authored in gamma space, co-tuned with the
		// linear lightingSpecular alpha carried in frag_color1.
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
#endif
		base = (color1 + color1.a) * color0;
	}
	else
	{
		// default case, modulate
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color1;
#endif
		// Phase 6B3'-d4-A5 / m_final: lightmap boost on color1 in linear
		// domain. The lightmap texel is stored byte-verbatim now
		// (R_ColorShiftLightingBytes no longer << 1's it); the ×2.0 happens
		// here, after sampleColorTex's sRGB → linear decode.
		base.rgb = color0.rgb * color1.rgb * LIGHTMAP_BOOST;
		base.a   = color0.a * color1.a;
	}
#else
	// double-texture with identity colors (1.0) in color1
	if ( tex_mode == 1 )
	{
		// add (identity)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
		base = vec4(color0.rgb + color1.rgb, color0.a * color1.a);
	}
	else if ( tex_mode == 2 )
	{
		// add
#if defined (USE_CLX_IDENT)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
#elif defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color0;
#endif
		base = vec4(color0.rgb + color1.rgb, color0.a * color1.a);
	}
	else // default case
	{
		// modulate
#if defined (USE_FIXED_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * frag_color;
#elif defined (USE_ENT_COLOR)
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1) * ent_color1;
#else
		vec4 color1 = sampleColorTex(texture1, frag_tex_coord1, 1);
#endif
		// Phase 6B3'-d4-A5 / m_final: lightmap boost on color1 in linear
		// domain. The lightmap texel is stored byte-verbatim now
		// (R_ColorShiftLightingBytes no longer << 1's it); the ×2.0 happens
		// here, after sampleColorTex's sRGB → linear decode.
		base.rgb = color0.rgb * color1.rgb * LIGHTMAP_BOOST;
		base.a   = color0.a * color1.a;
	}
#endif // !USE_CL1
#endif // !USE_TX1

#if !defined(USE_TX1)
	base = color0;
#endif

#ifdef USE_ATEST
#if 0
	if (alpha_to_coverage != 0) {
		if (alpha_test_func == 1) {
			base.a =  base.a > 0.0 ? 1.0 : 0.0;
		} else if (alpha_test_func == 2) {
			base.a = CorrectAlpha(alpha_test_value, 1.0 - base.a, frag_tex_coord0);
		} else if (alpha_test_func == 3) {
			base.a = CorrectAlpha(alpha_test_value, base.a, frag_tex_coord0);
		}
	} else
#endif
	// specialization: alpha-test function
	if (alpha_test_func == 1) {
		if (color0.a == alpha_test_value) discard;
	} else if (alpha_test_func == 2) {
		if (color0.a >= alpha_test_value) discard;
	} else if (alpha_test_func == 3) {
		if (color0.a < alpha_test_value) discard;
	}
#endif

#if !defined(USE_TX1) && !defined(USE_TX2)
	base = color0;
#endif

#ifdef USE_FOG
	// Phase 6B3'-d4-m4: fogColor is host-decoded to linear domain
	// (VK_SetFogParams — the single UBO fill site). `fog` (sampled from
	// fog_texture at the top of main) is a non-colour density ramp, not
	// decoded. The blend math below is unchanged; it now operates on
	// linear inputs.
	if ( acff == 1 ) {
		// ACFF_RGB
		base.rgb = base.rgb * (1.0 - fog.w);
	} else if ( acff == 2 ) {
		// ACFF_RGBA
		base = base * (1.0 - fog.w);
	} else if ( acff == 3 ) {
		// ACFF_ALPHA
		base.a = base.a * (1.0 - fog.w);
	} else {
		// default: ACFF_NONE
		base = mix( base, fog * fogColor, fog.a );
	}
#endif

	if ( discard_mode == 1 ) {
		if ( base.a == 0.0 ) {
			discard;
		}
	} else if ( discard_mode == 2 ) {
		if ( dot( base.rgb, base.rgb ) == 0.0 ) {
			discard;
		}
	}

#ifdef USE_DEPTH_FADE
	{
		// soft particle depth fade: compare fragment depth with scene depth
		vec2 screenUV = gl_FragCoord.xy / vec2(textureSize(depth_texture, 0));
		float sceneDepth = texture(depth_texture, screenUV).r;
		float fragDepth = gl_FragCoord.z;
#ifdef USE_REVERSED_DEPTH
		float depthDiff = fragDepth - sceneDepth;
#else
		float depthDiff = sceneDepth - fragDepth;
#endif
		float fadeFactor = smoothstep(0.0, depth_fade_scale * 0.0005, depthDiff);
		base.a *= fadeFactor;
		base.rgb *= fadeFactor;
	}
#endif

#ifdef USE_DF
	if ( base.a < depth_fragment )
		discard;

	gl_FragDepth = gl_FragCoord.z;
#else
	out_color = base;
#endif
}
