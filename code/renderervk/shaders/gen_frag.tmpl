layout (constant_id = 3) const int alpha_to_coverage = 0;
// Block 5d: per-slot colour-domain bitmask. Bit N set => texture slot N is
// CD_LINEAR and is fetched raw; bit N clear => CD_SRGB, decoded via
// sRGBToLinear at sample time. Host-filled from each stage's bundle images
// (Vk_Pipeline_Def.tex_domain). Reuses spec-constant id 4 (the ex-color_mode
// slot, which color.frag still uses for its own white/green/red mode — a
// pipeline is exactly one shader type, so the id is unambiguous).
layout (constant_id = 4) const int tex_domain = 0;
//layout (constant_id = 5) const int abs_light = 0;
#if defined (USE_TX1) || defined(USE_TX2)
layout (constant_id = 6) const int tex_mode = 0; // modulate, add (identity), add(non-identity) etc
#endif
layout (constant_id = 7) const int discard_mode = 0;

// Phase 6B3'-d4-m_final (Block 1): the A3-era per-map `srgb` spec
// constant (id 15) and the worldLinearize* opt-in are retired. The
// engine is now self-consistently linear end-to-end: sampleColorTex
// below decodes every colour texel unconditionally, and LIGHTMAP_BOOST
// is applied unconditionally. Spec-constant id 15 is left a hole (ids
// are not required contiguous; renumbering would risk drift in the
// host-side map).

// Phase 6B3'-d4-A5 / m_final: linear-domain lightmap boost. q3map2
// emits lightmap bytes at half-intensity expecting an engine-side
// doubling. The byte-space `<< 1` (R_ColorShiftLightingBytes) was
// incorrect in sRGB (byte 128 doubled to 255 is ~4× linear light,
// not 2×); the lightmap-texel call sites now store the byte verbatim
// and the ×2.0 happens here, in linear domain, on color1 (the
// lightmap in the modulate-default MUL2/MUL3 collapse: bundle[0]=
// diffuse, bundle[1]=lightmap, bundle[2]=third stage — verified in
// tr_shader.c CollapseMultitexture), AFTER sampleColorTex's
// sRGB → linear decode. Only the modulate-default branches: add/mix/
// blend branches don't have a lightmap in color1.
const float LIGHTMAP_BOOST = 2.0;

#ifdef USE_FIXED_COLOR
layout (constant_id = 8) const float identity_color = 1.0;
layout (constant_id = 9) const float identity_alpha = 1.0;
#endif

#ifdef USE_FOG
layout (constant_id = 10) const int acff = 0; // NONE, RGB, RGBA, ALPHA
#endif

#ifdef USE_ATEST
#if 0
