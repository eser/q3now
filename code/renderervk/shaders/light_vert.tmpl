#version 450

// 64 bytes
layout(push_constant) uniform Transform {
	mat4 mvp;
};

layout(set = 0, binding = 0) uniform UBO {
	// light/env parameters:
	vec4 eyePos;				// vertex
	vec4 lightPos;				// vertex: light origin
	vec4 lightColor;			// fragment: rgb + 1/(r*r)
	vec4 lightVector;			// fragment: linear dynamic light
#ifdef USE_FOG
	// fog parameters:
	vec4 fogDistanceVector;		// vertex
	vec4 fogDepthVector;		// vertex
	vec4 fogEyeT;				// vertex
	vec4 fogColor;				// fragment
#endif
	// Phase 6.5.4c: the CSM cascade matrices / split distances live further on
	// in this UBO (std140 offsets 144 / 400) and are only consumed by the
	// fragment stage, so the vertex stage doesn't declare them here (a std140
	// prefix is fine).
#ifdef USE_SHADOWMAP
	// Phase 6.5.4d2: caster/receiver model→world transform (identity for
	// worldspawn, the entity's [axis|origin] for entity/brush-model surfaces) —
	// used below to put shadowData.xyz in WORLD space. Host offset 416 (see
	// code/renderervk/vk.h vkUniform_t.modelMatrix). Phase 7.3b-followup:
	// explicit `layout(offset=)` replaced with natural std140 padding so the
	// block translates under every backend (the frag stage's cascadeMVP[4] +
	// cascadeSplits cover 144..416 in the host struct — the vert stage doesn't
	// reference them, just pads over them).
#ifdef USE_FOG
	vec4 _pad_to_modelMatrix[18];   //  128 → 416 (288 bytes, after fogColor)
#else
	vec4 _pad_to_modelMatrix[22];   //   64 → 416 (352 bytes, after lightVector)
#endif
	mat4 modelMatrix;               // offset 416, 64 bytes
#endif
};

layout(location = 0) in vec3 in_position;
layout(location = 1) in vec2 in_tex_coord;
layout(location = 2) in vec3 in_normal;

layout(location = 0) out vec2 frag_tex_coord;
layout(location = 1) out vec3 N; // normal array 
layout(location = 2) out vec4 L; // object-space light vector
layout(location = 3) out vec4 V; // object-space view vector

#ifdef USE_FOG
layout(location = 4) out vec2 fog_tex_coord;
#endif
#ifdef USE_PARALLAX
layout(location = 5) out vec3 frag_position; // object-space position for TBN
#endif
#ifdef USE_SHADOWMAP
layout(location = 6) out vec4 shadowData;     // xyz = object/world position, w = view-space depth (gl_Position.w)
#endif

out gl_PerVertex {
	vec4 gl_Position;
};

void main() {
	gl_Position = mvp * vec4(in_position, 1.0);

	frag_tex_coord = in_tex_coord;
	N = in_normal;
	L = lightPos - vec4(in_position, 1.0);
	V = eyePos - vec4(in_position, 1.0);
#ifdef USE_PARALLAX
	frag_position = in_position;
#endif
#ifdef USE_SHADOWMAP
	// World-space fragment position (for the fragment's per-cascade light-space
	// transform) + view-space depth (== gl_Position.w for a perspective
	// projection) for the cascade selector. Phase 6.5.4d2: in_position is
	// object-space for entity surfaces / rest-space for moved brush models, so
	// it's mapped through modelMatrix here — worldspawn surfaces get an identity
	// modelMatrix, so this is a no-op for them. Closes the 6.5.4c caveat.
	shadowData = vec4( ( modelMatrix * vec4( in_position, 1.0 ) ).xyz, gl_Position.w );
#endif

#ifdef USE_FOG
	float s = dot(in_position, fogDistanceVector.xyz) + fogDistanceVector.w;
	float t = dot(in_position, fogDepthVector.xyz) + fogDepthVector.w;

	if ( fogEyeT.y == 1.0 ) {
		if ( t < 0.0 ) {
			t = 1.0 / 32.0;
		} else {
			t = 31.0 / 32.0;
		}
	} else {
		if ( t < 1.0 ) {
			t = 1.0 / 32.0;
		} else {
			t = 1.0 / 32.0 + (30.0 / 32.0 * t) / ( t - fogEyeT.x );
		}
	}

	fog_tex_coord = vec2(s, t);
#endif
}
