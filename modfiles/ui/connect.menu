// connect.menu - Wired UI connection progress
// Ports: code/q3_ui/ui_connect.c

#include "ui/menumacros.h"

menuDef {
	name "connect"
	fullScreen 1
	rect 0 0 640 480
	style 1
	backcolor 0.05 0.05 0.1 1

	LABEL(200, 200, 240, 24, "Connecting...", 0.5, 1)
	LABEL_COLOR(200, 230, 240, 16, "Please wait", 0.35, 1, 0.5, 0.5, 0.5, 1)

	itemDef {
		type 1
		text "Cancel"
		rect 270 300 100 24
		textalign 1
		textscale 0.4
		forecolor 1 0.75 0 1
		visible 1
		action { exec "disconnect" }
	}
}
