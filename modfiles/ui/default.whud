	// ── Team Overlay ────────────────────────────────────────
	itemDef { hudElement "team8"   anchor BOTTOM_LEFT  rect 0.006 0.708 0 0.021  font "defaultMonoFont"  fontsize 6 10  monospace  forecolor 1 1 1 1  backcolor 0.75 0.75 0.75 0.25  fill }
	itemDef { hudElement "team7"   anchor BOTTOM_LEFT  rect 0.006 0.729 0 0.021  font "defaultMonoFont"  fontsize 6 10  monospace  forecolor 1 1 1 1  backcolor 0.75 0.75 0.75 0.25  fill }
	itemDef { hudElement "team6"   anchor BOTTOM_LEFT  rect 0.006 0.750 0 0.021  font "defaultMonoFont"  fontsize 6 10  monospace  forecolor 1 1 1 1  backcolor 0.75 0.75 0.75 0.25  fill }
	itemDef { hudElement "team5"   anchor BOTTOM_LEFT  rect 0.006 0.771 0 0.021  font "defaultMonoFont"  fontsize 6 10  monospace  forecolor 1 1 1 1  backcolor 0.75 0.75 0.75 0.25  fill }
	itemDef { hudElement "team4"   anchor BOTTOM_LEFT  rect 0.006 0.792 0 0.021  font "defaultMonoFont"  fontsize 6 10  monospace  forecolor 1 1 1 1  backcolor 0.75 0.75 0.75 0.25  fill }
	itemDef { hudElement "team3"   anchor BOTTOM_LEFT  rect 0.006 0.813 0 0.021  font "defaultMonoFont"  fontsize 6 10  monospace  forecolor 1 1 1 1  backcolor 0.75 0.75 0.75 0.25  fill }
	itemDef { hudElement "team2"   anchor BOTTOM_LEFT  rect 0.006 0.833 0 0.021  font "defaultMonoFont"  fontsize 6 10  monospace  forecolor 1 1 1 1  backcolor 0.75 0.75 0.75 0.25  fill }
	itemDef { hudElement "team1"   anchor BOTTOM_LEFT  rect 0.006 0.854 0 0.021  font "defaultMonoFont"  fontsize 6 10  monospace  forecolor 1 1 1 1  backcolor 0.75 0.75 0.75 0.25  fill }

	// ── Awards ──────────────────────────────────────────────
	itemDef { hudElement "awards"
