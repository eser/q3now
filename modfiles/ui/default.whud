	// ── Flag Status (CTF) ───────────────────────────────────
	itemDef { hudElement "flagstatus_own"  anchor TOP_CENTER  rect 0.338 0.004 0.022 0.042  forecolor 1 1 1 1 }
	itemDef { hudElement "flagstatus_nme"  anchor TOP_CENTER  rect 0.663 0.004 0.022 0.042  forecolor 1 1 1 1 }

